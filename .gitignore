# プロジェクトの除外パス
# Android / Gradle
/.gradle/
**/build/
.idea/
*.iml
/app/release/

# 機密・環境依存
local.properties
keystore.properties
*.jks
*.keystore
*.pem
*.p12

# Firebase
app/google-services.json

# 問題データの保護
# master_data は Git 管理するが、assets 内のプレーンな JSON は除外する
app/src/main/assets/**/*.json
quiz-core-data/src/main/assets/**/*.json
