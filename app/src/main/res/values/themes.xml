<resources>
    <!-- メインテーマ -->
    <style name="Theme.SocialworkerHumanMed" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="android:statusBarColor">?android:attr/colorBackground</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- スプラッシュ画面用テーマ (Android 12+) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- 背景色: アプリの背景と同じ極めて淡いグリーン -->
        <item name="windowSplashScreenBackground">#F1F8E9</item>
        <!-- アイコン: 作成したクイズアイコンの前景 -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- スプラッシュ終了後に表示するテーマ -->
        <item name="postSplashScreenTheme">@style/Theme.SocialworkerHumanMed</item>
    </style>
</resources>
